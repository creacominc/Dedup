            "preLaunchTask": "swift: Build Debug Dedup",
            "stopOnEntry": false,
            "target": "Dedup",
            "configuration": "debug"
        },
        {
            "name": "Debug Dedup (Direct)",
            "type": "lldb",
            "request": "launch",
            "program": "~/Library/Developer/Xcode/DerivedData/Dedup-dwyurlrejkgpvvdxinipacztiapy/Build/Products/Debug/Dedup.app/Contents/MacOS/Dedup",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Dedup",
            "stopOnEntry": false,
            "console": "integratedTerminal"
        },
        {
            "name": "Attach to Dedup",
            "type": "lldb",
            "request": "attach",
            "program": "~/Library/Developer/Xcode/DerivedData/Dedup-dwyurlrejkgpvvdxinipacztiapy/Build/Products/Debug/Dedup.app/Contents/MacOS/Dedup",
            "stopOnEntry": false
        },
        {
            "type": "swift",
            "request": "launch",
            "args": [],
            "cwd": "${workspaceFolder:Dedup}",
            "name": "Release Dedup",
            "preLaunchTask": "swift: Build Release Dedup",
            "target": "Dedup",
            "configuration": "release"
        },
        {
            "name": "Run Unit Tests",
            "type": "lldb",
            "request": "launch",
            "program": "/usr/bin/xcodebuild",
            "args": [
                "-project",
                "${workspaceFolder}/Dedup.xcodeproj",
                "-scheme",
                "Dedup",
                "-destination",
                "platform=macOS",
                "-only-testing:DedupTests",
                "test"
