        {
            "label": "Test Unit Tests Only",
            "type": "shell",
            "command": "xcodebuild",
            "args": [
                "-project",
                "Dedup.xcodeproj",
                "-scheme",
                "Dedup",
                "-destination",
                "platform=macOS",
                "-only-testing:DedupTests",
                "test"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
