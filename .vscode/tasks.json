{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Dedup",
            "type": "shell",
            "command": "xcodebuild",
            "args": [
                "-project",
                "Dedup.xcodeproj",
                "-scheme",
                "Dedup",
                "-configuration",
                "Debug",
                "build"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Clean Build",
            "type": "shell",
            "command": "xcodebuild",
            "args": [
                "-project",
                "Dedup.xcodeproj",
                "-scheme",
                "Dedup",
                "-configuration",
                "Debug",
                "clean",
                "build"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Test Dedup",
            "type": "shell",
            "command": "xcodebuild",
            "args": [
                "-project",
                "Dedup.xcodeproj",
                "-scheme",
                "Dedup",
                "-configuration",
                "Debug",
                "test"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Prepare Debug App",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "APP_PATH=$(find ~/Library/Developer/Xcode/DerivedData -name 'Dedup.app' -type d 2>/dev/null | head -1) && if [ -z \"$APP_PATH\" ]; then echo 'App not found in DerivedData' >&2; exit 1; fi && mkdir -p ./build/Debug && rm -rf ./build/Debug/Dedup.app && cp -R \"$APP_PATH\" ./build/Debug/Dedup.app && echo \"Copied app from: $APP_PATH\""
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        },
        {
            "label": "Build and Prepare Debug",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build Dedup",
                "Prepare Debug App"
            ],
            "group": "build"
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "xcodebuild",
            "args": [
                "-project",
                "Dedup.xcodeproj",
                "-scheme",
                "Dedup",
                "clean"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Build Release",
            "type": "shell",
