                "Dedup.xcodeproj",
                "-scheme",
                "Dedup",
                "-destination",
                "platform=macOS",
                "-only-testing:DedupUITests",
                "test"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
